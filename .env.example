# Autentizace — symetrický klíč pro šifrování session cookie a integration credentials
SESSION_SECRET=change-me-to-a-random-32-byte-hex-string
INTEGRATION_ENC_KEY=change-me-to-a-random-32-byte-hex-string

# GitHub integration default token pro dev (volitelné)
# GITHUB_TOKEN=

# Demo admin override (nastav na 1 pro vypnutí auth v lokálním dev)
# NEXT_PUBLIC_AUTH_DISABLED=0
