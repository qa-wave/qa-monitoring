# Required in production
SESSION_SECRET=change-me-to-a-random-32-byte-hex-string
INTEGRATION_ENC_KEY=change-me-to-a-random-32-byte-hex-string

# Vercel Blob (auto-set when blob store linked)
# BLOB_READ_WRITE_TOKEN=

# Database (optional -- Neon Postgres)
# DATABASE_URL=postgresql://...

# Integrations
# GITHUB_WEBHOOK_SECRET=
# SENTRY_WEBHOOK_SECRET=
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# Cron
# CRON_SECRET=

# Analytics (auto-set on Vercel)
# VERCEL_ANALYTICS_ID=

# Dev overrides
# NEXT_PUBLIC_AUTH_DISABLED=0
